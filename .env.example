# BriefAI Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env.local for local development
# Add these in Vercel Dashboard → Settings → Environment Variables for production
# ─────────────────────────────────────────────────────────

# REQUIRED — Anthropic Claude API
# Get your key at: https://console.anthropic.com
# Free $5 credit on signup — enough for hundreds of briefs
ANTHROPIC_API_KEY=sk-ant-api03-...

# OPTIONAL BUT RECOMMENDED — NewsAPI (Real news data)
# Get your FREE key at: https://newsapi.org/register
# Free tier: 100 requests/day — plenty for a demo
# Without this, Claude uses only its training knowledge (still works!)
NEWS_API_KEY=your_newsapi_key_here
